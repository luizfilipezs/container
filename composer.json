{
  "name": "luizfilipezs/container",
  "description": "Dependency injection container",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Luiz Filipe da Silva",
      "email": "filipeluiz.bs@gmail.com"
    }
  ],
  "scripts": {
    "fix": "php-cs-fixer fix",
    "test": "phpunit tests"
  },
  "require": {
    "php": "^8.4",
    "psr/container": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Luizfilipezs\\Container\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Luizfilipezs\\Container\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
