{
  "name": "luizfilipezs/container",
  "description": "A PHP dependency injection container with native lazy construction support.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Luiz Filipe da Silva",
      "email": "luizfilipezs@proton.me"
    }
  ],
  "scripts": {
    "fix": "php-cs-fixer fix",
    "test": "phpunit tests"
  },
  "require": {
    "php": "^8.4",
    "psr/container": "^2.0.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1.7",
    "friendsofphp/php-cs-fixer": "^3.95.1"
  },
  "autoload": {
    "psr-4": {
      "Luizfilipezs\\Container\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Luizfilipezs\\Container\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
